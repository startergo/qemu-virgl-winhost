--- qemu-10.1.2/ui/sdl2-clipboard.c	1969-12-31 19:00:00
+++ qemu-10.1.2-patched/ui/sdl2-clipboard.c	2025-11-26 09:07:45
@@ -0,0 +1,194 @@
+/*
+ * SDL UI -- clipboard support
+ *
+ * Copyright (C) 2023 Kamay Xutax <admin@xutaxkamay.com>
+ * Copyright (C) 2025 startergo <startergo@users.noreply.github.com>
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#include "qemu/osdep.h"
+#include "ui/console.h"
+#include "ui/clipboard.h"
+#include "ui/sdl2.h"
+
+/*
+ * Counts how many SDL_CLIPBOARDUPDATE events to suppress after we call
+ * SDL_SetClipboardText() with guest data.  Windows fires WM_CLIPBOARDUPDATE
+ * after CloseClipboard(); set to 1 each time we write to the SDL clipboard
+ * so the resulting echo does not steal clipboard ownership from the guest.
+ */
+static int suppress_clipboard_echo;
+
+/*
+ * Set while we have an outstanding asynchronous request for guest clipboard
+ * data.  Prevents sdl2_clipboard_handle_request from announcing host
+ * clipboard ownership (which would cancel the in-flight transfer).
+ */
+static bool guest_clipboard_pending;
+
+/*
+ * Last text pushed to QEMU from the host side.  Used to skip duplicate
+ * SDL_CLIPBOARDUPDATE events (e.g. from KDE Klipper re-announcing the same
+ * content on focus changes).
+ */
+static char *last_host_text;
+
+static void sdl2_clipboard_notify(Notifier *notifier, void *data)
+{
+    QemuClipboardNotify *notify = data;
+    struct sdl2_console *scon =
+        container_of(notifier, struct sdl2_console, cbpeer.notifier);
+
+    switch (notify->type) {
+    case QEMU_CLIPBOARD_UPDATE_INFO:
+        /*
+         * self_update check must be inside UPDATE_INFO: for RESET_SERIAL,
+         * notify->info may be NULL and dereferencing it before the switch
+         * would crash.
+         */
+        if (notify->info->owner == &scon->cbpeer) {
+            return;
+        }
+        if (!notify->info->types[QEMU_CLIPBOARD_TYPE_TEXT].available) {
+            return;
+        }
+        if (!notify->info->types[QEMU_CLIPBOARD_TYPE_TEXT].data) {
+            /*
+             * Data not yet available — request it from the guest.
+             * QEMU's internal "requested" flag prevents duplicate requests
+             * for the same info object.
+             */
+            guest_clipboard_pending = true;
+            qemu_clipboard_request(notify->info, QEMU_CLIPBOARD_TYPE_TEXT);
+            return;
+        }
+        {
+            /* Data is available — push to the SDL (host) clipboard. */
+            size_t text_size =
+                notify->info->types[QEMU_CLIPBOARD_TYPE_TEXT].size;
+            const char *text_data;
+            g_autofree char *text = NULL;
+
+            guest_clipboard_pending = false;
+            if (text_size == 0) {
+                return;
+            }
+            text_data =
+                (const char *)notify->info->types[QEMU_CLIPBOARD_TYPE_TEXT].data;
+            text = g_strndup(text_data, text_size);
+            if (text && text[0] != '\0') {
+                /*
+                 * Arm the echo counter before writing so that the Windows
+                 * WM_CLIPBOARDUPDATE event posted by CloseClipboard() is
+                 * caught by sdl2_clipboard_handle_request before it can
+                 * steal clipboard ownership from the guest.
+                 */
+                suppress_clipboard_echo = 1;
+                SDL_SetClipboardText(text);
+            }
+        }
+        break;
+    case QEMU_CLIPBOARD_RESET_SERIAL:
+        guest_clipboard_pending = false;
+        break;
+    }
+}
+
+static void sdl2_clipboard_request(QemuClipboardInfo *info,
+                                   QemuClipboardType type)
+{
+    char *text;
+
+    if (type != QEMU_CLIPBOARD_TYPE_TEXT) {
+        return;
+    }
+    text = SDL_GetClipboardText();
+    if (!text || !text[0]) {
+        if (text) {
+            SDL_free(text);
+        }
+        return;
+    }
+    qemu_clipboard_set_data(info->owner, info, type,
+                            strlen(text), text, true);
+    SDL_free(text);
+}
+
+void sdl2_clipboard_init(struct sdl2_console *scon)
+{
+    scon->cbpeer.name = "sdl2-clipboard";
+    scon->cbpeer.notifier.notify = sdl2_clipboard_notify;
+    scon->cbpeer.request = sdl2_clipboard_request;
+    scon->clipboard_active = true;
+    qemu_clipboard_peer_register(&scon->cbpeer);
+}
+
+void sdl2_clipboard_handle_focus_change(struct sdl2_console *scon,
+                                        bool gained_focus)
+{
+    if (gained_focus) {
+        scon->clipboard_active = true;
+    } else {
+        scon->clipboard_active = false;
+        guest_clipboard_pending = false;
+    }
+}
+
+void sdl2_clipboard_handle_request(struct sdl2_console *scon)
+{
+    QemuClipboardInfo *info;
+    char *text;
+
+    if (!scon->clipboard_active) {
+        return;
+    }
+    /*
+     * Do not announce host clipboard ownership while waiting for guest data;
+     * that would cancel the in-flight data response from the guest.
+     */
+    if (guest_clipboard_pending) {
+        return;
+    }
+    if (!SDL_HasClipboardText()) {
+        return;
+    }
+    text = SDL_GetClipboardText();
+    if (!text || !text[0]) {
+        if (text) {
+            SDL_free(text);
+        }
+        return;
+    }
+    /*
+     * Suppress the echo SDL_CLIPBOARDUPDATE that Windows posts after each
+     * SDL_SetClipboardText() call in sdl2_clipboard_notify.  The counter was
+     * armed to 1 before writing; it is decremented here and the event
+     * silently discarded.  Any genuine host clipboard change that arrives
+     * after the echo has been consumed is processed normally.
+     */
+    if (suppress_clipboard_echo > 0) {
+        suppress_clipboard_echo--;
+        SDL_free(text);
+        return;
+    }
+    /*
+     * Deduplicate: skip events where the host clipboard content has not
+     * changed since our last push to QEMU (e.g. KDE Klipper re-announcing
+     * the same text on a focus change).
+     */
+    if (last_host_text && strcmp(last_host_text, text) == 0) {
+        SDL_free(text);
+        return;
+    }
+    g_free(last_host_text);
+    last_host_text = g_strdup(text);
+
+    info = qemu_clipboard_info_new(&scon->cbpeer,
+                                   QEMU_CLIPBOARD_SELECTION_CLIPBOARD);
+    qemu_clipboard_set_data(&scon->cbpeer, info, QEMU_CLIPBOARD_TYPE_TEXT,
+                            strlen(text), text, false);
+    qemu_clipboard_update(info);
+    qemu_clipboard_info_unref(info);
+    SDL_free(text);
+}
